modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deploy to Cloudflare"

[[workflows.workflow]]
name = "Deploy to Cloudflare"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd worker && ./node_modules/.bin/wrangler deploy"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
CLOUDFLARE_ACCOUNT_ID = "d8849271816bf8825908efa8edc58162"

[[ports]]
localPort = 5000
externalPort = 80
