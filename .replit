modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Audio Converter"

[[workflows.workflow]]
name = "Audio Converter"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 bot/converter.py"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
CLOUDFLARE_ACCOUNT_ID = "d8849271816bf8825908efa8edc58162"
